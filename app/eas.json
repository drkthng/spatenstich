{
  "cli": { "version": ">= 18.0.0", "appVersionSource": "local" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "ENVIRONMENT": "dev" },
      "ios": { "simulator": true }
    },
    "preview": {
      "distribution": "internal",
      "env": { "ENVIRONMENT": "dev" },
      "ios": { "simulator": true }
    },
    "production": {
      "env": { "ENVIRONMENT": "prod" },
      "ios": { "image": "macos-sonoma-14.6-xcode-16.1" }
    }
  },
  "submit": { "production": {} }
}
